{
  "name": "programmers-badge-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @programmers-badge/web dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @programmers-badge/web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:e2el": "turbo run test:e2el",
    "test:api-coverage": "pnpm --filter @programmers-badge/api test:coverage",
    "package:extension": "pnpm --filter @programmers-badge/extension package",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e && pnpm test:api-coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.6"
  }
}
