{
  "manifest_version": 3,
  "name": "PROGRAMMERS-BADGE-V2",
  "version": "0.1.1",
  "description": "Sync Programmers badge data and prepare a hosted badge URL.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": ["https://api.programmers-badge.jh8459.com/*"],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://school.programmers.co.kr/learn/courses/*/lessons/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "PROGRAMMERS-BADGE-V2",
    "default_popup": "popup.html"
  }
}
