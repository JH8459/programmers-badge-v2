{
  "name": "@programmers-badge/extension",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@programmers-badge/shared-types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.319",
    "esbuild": "^0.27.4"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch",
    "build": "node scripts/build-extension.mjs && node scripts/copy-assets.mjs",
    "package": "node scripts/package-extension.mjs",
    "lint": "eslint src test scripts --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
