{
  "name": "@programmers-badge/extension",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@programmers-badge/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.319"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch",
