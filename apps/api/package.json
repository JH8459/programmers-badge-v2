{
  "name": "@programmers-badge/api",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.20",
    "@nestjs/core": "^11.0.20",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.0.20",
    "@programmers-badge/badge-core": "workspace:*",
    "@programmers-badge/shared-types": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "pnpm --filter @programmers-badge/shared-types build && pnpm --filter @programmers-badge/badge-core build && nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src test --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21"
  }
}
